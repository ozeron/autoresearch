{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "__REPO_ROOT__/scripts/session-start.sh",
            "statusMessage": "Loading autoresearch context"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "__REPO_ROOT__/scripts/stop-guard.sh",
            "timeout": 30,
            "statusMessage": "Checking autoresearch loop"
          }
        ]
      }
    ]
  }
}
